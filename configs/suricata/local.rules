# ============================================================
# local.rules — Règles Suricata personnalisées
# Projet NSM Lab — DIC2 Cybersécurité ESP Dakar
# ============================================================

# ── Détection ICMP (Ping) ───────────────────────────────────
alert icmp any any -> $HOME_NET any \
    (msg:"NSM - Ping détecté vers le réseau interne"; \
    itype:8; sid:1000001; rev:1;)

alert icmp $HOME_NET any -> any any \
    (msg:"NSM - Ping sortant détecté"; \
    itype:8; sid:1000002; rev:1;)

# ── Scan de ports ───────────────────────────────────────────
alert tcp any any -> $HOME_NET any \
    (msg:"NSM - Scan de ports détecté (SYN)"; \
    flags:S; threshold:type threshold, track by_src, \
    count 20, seconds 5; \
    sid:1000003; rev:1;)

alert tcp any any -> $HOME_NET any \
    (msg:"NSM - Scan Nmap détecté"; \
    flags:SF; sid:1000004; rev:1;)

# ── Détection ARP Spoofing ──────────────────────────────────
alert arp any any -> any any \
    (msg:"NSM - ARP Spoofing possible détecté"; \
    arp.opcode:2; sid:1000005; rev:1;)

# ── Tentatives de connexion SSH ─────────────────────────────
alert tcp any any -> $HOME_NET 22 \
    (msg:"NSM - Tentative connexion SSH"; \
    flags:S; sid:1000006; rev:1;)

alert tcp any any -> $HOME_NET 22 \
    (msg:"NSM - Brute force SSH détecté"; \
    flags:S; threshold:type threshold, track by_src, \
    count 5, seconds 60; \
    sid:1000007; rev:1;)

# ── Trafic HTTP suspect ─────────────────────────────────────
alert http any any -> $HOME_NET any \
    (msg:"NSM - Tentative SQL Injection détectée"; \
    content:"UNION SELECT"; nocase; \
    sid:1000008; rev:1;)

alert http any any -> $HOME_NET any \
    (msg:"NSM - Tentative XSS détectée"; \
    content:"<script>"; nocase; \
    sid:1000009; rev:1;)

# ── DNS suspect ─────────────────────────────────────────────
alert dns any any -> any any \
    (msg:"NSM - Requête DNS volumineuse (tunneling possible)"; \
    dsize:>100; sid:1000010; rev:1;)

# ── NetFlow anomalie ────────────────────────────────────────
alert tcp any any -> $HOME_NET any \
    (msg:"NSM - Volume trafic anormal détecté"; \
    threshold:type threshold, track by_src, \
    count 1000, seconds 10; \
    sid:1000011; rev:1;)
